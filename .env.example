# LLM providers — set ONE or MORE. The app tries them in this order and
# automatically falls through to the next when one hits its rate limit, so
# adding a second provider multiplies your free daily headroom.

# Google Gemini — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — free, very generous, instant signup at https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant   # optional override

# OpenRouter — free models, key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Cerebras — free, fast, https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# These two are NOT needed locally — set them as GitHub repo secrets instead:
#   GMAIL_ADDRESS        your gmail address
#   GMAIL_APP_PASSWORD   app password from https://myaccount.google.com/apppasswords
